#: src/code/syncing.cpp:207
#, kde-format
msgid ""
"The remote server requires authentication to serve the content but the "
"credentials provided were not accepted (if any)"
msgstr ""
"Vzdialený server vyžaduje overenie na poskytnutie obsahu, ale poskytnuté "
"prihlasovacie údaje neboli prijaté (ak boli)"

#: src/code/syncing.cpp:211
#, kde-format
msgid ""
"the remote server refused the connection (the server is not accepting "
"requests"
msgstr "vzdialený server odmietol pripojenie (server neprijíma požiadavky)"

#: src/code/syncing.cpp:215
#, kde-format
msgid ""
"the remote server closed the connection prematurely, before the entire reply "
"was received and processed"
msgstr ""
"vzdialený server predčasne zatvoril pripojenie, pred prijatím a spracovaním "
"celej odpovede"

#: src/code/syncing.cpp:219
#, kde-format
msgid "the remote host name was not found (invalid hostname)"
msgstr "vzdialený názov hostiteľa nebol nájdený (neplatný názov hostiteľa)"

#: src/code/syncing.cpp:223
#, kde-format
msgid "the connection to the remote server timed out"
msgstr "pripojenie k vzdialenému serveru vypršalo"

#: src/code/syncing.cpp:227
#, kde-format
msgid ""
"the operation was canceled via calls to abort() or close() before it was "
"finished."
msgstr ""
"operácia bola zrušená volaním abort() alebo close() pred jej dokončením."

#: src/code/syncing.cpp:231
#, kde-format
msgid ""
"the SSL/TLS handshake failed and the encrypted channel could not be "
"established. The sslErrors() signal should have been emitted."
msgstr ""
"SSL/TLS handshake zlyhal a šifrovaný kanál sa nepodarilo nadviazať. Mal byť "
"emitovaný signál sslErrors()."

#: src/code/syncing.cpp:236
#, kde-format
msgid ""
"the connection was broken due to disconnection from the network, however the "
"system has initiated roaming to another access point. The request should be "
"resubmitted and will be processed as soon as the connection is re-"
"established."
msgstr ""
"pripojenie bolo prerušené kvôli odpojeniu od siete, avšak systém inicioval "
"roaming na iný prístupový bod. Požiadavka by mala byť znova odoslaná a bude "
"spracovaná hneď po obnovení pripojenia."

#: src/code/syncing.cpp:240
#, kde-format
msgid ""
"the connection was broken due to disconnection from the network or failure "
"to start the network."
msgstr ""
"pripojenie bolo prerušené kvôli odpojeniu od siete alebo zlyhaniu spustenia "
"siete."

#: src/code/syncing.cpp:244
#, kde-format
msgid "the background request is not currently allowed due to platform policy."
msgstr ""
"požiadavka na pozadí nie je momentálne povolená kvôli politike platformy."

#: src/code/syncing.cpp:248
#, kde-format
msgid ""
"while following redirects, the maximum limit was reached. The limit is by "
"default set to 50 or as set by QNetworkRequest::setMaxRedirectsAllowed(). "
"(This value was introduced in 5.6.)"
msgstr ""
"pri nasledovaní presmerovaní bol dosiahnutý maximálny limit. Limit je "
"predvolene nastavený na 50 alebo podľa QNetworkRequest::"
"setMaximumRedirectsAllowed()."

#: src/code/syncing.cpp:252
#, kde-format
msgid ""
"while following redirects, the network access API detected a redirect from a "
"encrypted protocol (https) to an unencrypted one (http)."
msgstr ""
"pri nasledovaní presmerovaní rozhranie API sieťového prístupu zistilo "
"presmerovanie zo šifrovaného protokolu (https) na nešifrovaný (http)."

#: src/code/syncing.cpp:256
#, kde-format
msgid ""
"the connection to the proxy server was refused (the proxy server is not "
"accepting requests)"
msgstr ""
"pripojenie k proxy serveru bolo odmietnuté (proxy server neprijíma "
"požiadavky)"

#: src/code/syncing.cpp:260
#, kde-format
msgid ""
"the proxy server closed the connection prematurely, before the entire reply "
"was received and processed"
msgstr ""
"proxy server predčasne zatvoril pripojenie, pred prijatím a spracovaním "
"celej odpovede"

#: src/code/syncing.cpp:264
#, kde-format
msgid "the proxy host name was not found (invalid proxy hostname)"
msgstr "názov hostiteľa proxy nebol nájdený (neplatný názov hostiteľa proxy)"

#: src/code/syncing.cpp:268
#, kde-format
msgid ""
"the connection to the proxy timed out or the proxy did not reply in time to "
"the request sent"
msgstr ""
"pripojenie k proxy vypršalo alebo proxy neodpovedalo včas na odoslanú "
"požiadavku"

#: src/code/syncing.cpp:272
#, kde-format
msgid ""
"the proxy requires authentication in order to honour the request but did not "
"accept any credentials offered (if any)"
msgstr ""
"proxy vyžaduje overenie na vybavenie požiadavky, ale neprijalo žiadne "
"ponúknuté prihlasovacie údaje (ak boli)"

#: src/code/syncing.cpp:276
#, kde-format
msgid "the access to the remote content was denied (similar to HTTP error 403)"
msgstr "prístup k vzdialenému obsahu bol zamietnutý (podobné chybe HTTP 403)"

#: src/code/syncing.cpp:280
#, kde-format
msgid "the operation requested on the remote content is not permitted"
msgstr "požadovaná operácia na vzdialenom obsahu nie je povolená"

#: src/code/syncing.cpp:284
#, kde-format
msgid ""
"the remote content was not found at the server (similar to HTTP error 404)"
msgstr "vzdialený obsah nebol nájdený na serveri (podobné chybe HTTP 404)"

#: src/code/syncing.cpp:288
#, kde-format
msgid ""
"the request needed to be sent again, but this failed for example because the "
"upload data could not be read a second time."
msgstr ""
"požiadavka musela byť odoslaná znova, ale zlyhalo to napríklad preto, že "
"údaje na nahrávanie nebolo možné prečítať druhýkrát."

#: src/code/syncing.cpp:292
#, kde-format
msgid "the server is unable to handle the request at this time."
msgstr "server v tejto chvíli nie je schopný spracovať požiadavku."

#: src/code/syncing.cpp:296
#, kde-format
msgid ""
"There was an unknown error with the remote server or your internet "
"connection."
msgstr ""
"Vyskytla sa neznáma chyba so vzdialeným serverom alebo vaším internetovým "
"pripojením."

